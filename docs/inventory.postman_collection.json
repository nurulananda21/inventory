{
	"info": {
		"name": "Inventory API v1",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Register",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Accept", "value": "application/json", "type": "text" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Ananda\",\n    \"email\": \"ananda123@gmail.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "http://127.0.0.1:8000/api/v1/register", "protocol": "http", "host": ["127", "0", "0", "1"], "port": "8000", "path": ["api", "v1", "register"] }
			}
		},
